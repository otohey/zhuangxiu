        <mxCell id="aenydGY1BiXlo850nxzo-28" value="&lt;span style=&quot;font-size: 16px;&quot;&gt;软装入场&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;flipV=0;" parent="1" vertex="1">
