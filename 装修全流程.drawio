        <mxCell id="aenydGY1BiXlo850nxzo-36" value="乳胶漆：&lt;div&gt;1、墙面滚涂，吊顶喷涂&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
